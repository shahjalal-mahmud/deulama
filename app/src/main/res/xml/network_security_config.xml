<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG ONLY. Android 9+ (API 28) blocks cleartext (http://) traffic by
  default. This file whitelists cleartext only for local development hosts
  so Retrofit can hit a local XAMPP/Laragon PHP server without HTTPS.

  Hosts allowed below:
    - 10.0.2.2          : Android emulator's loopback alias to the host
                          machine's 127.0.0.1
    - 192.168.1.42      : Example LAN IP of the dev machine. Edit this to
                          match your own machine if you test on a physical
                          device over Wi-Fi.
    - 127.0.0.1 / localhost : Kept for completeness (e.g. instrumented
                          tests), but you should NOT rely on these from a
                          real device or emulator -- they point to the
                          device itself.

  Add another <domain> entry for any other dev IP you need.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">192.168.1.42</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>